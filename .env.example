# ═══════════════════════════════════════════════════════════════════
# AtlasAI — Environment Variables (Production)
# Copy this to .env and fill in your values before deploying.
# ═══════════════════════════════════════════════════════════════════

# ─── PostgreSQL ─────────────────────────────────
DB_USER=atlasai
DB_PASSWORD=atlasai_secret
DB_NAME=atlasai

# ─── JWT (MUST be the same across all services) ─
# Generate with: openssl rand -base64 64
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ─── Oracle Cloud / VPS Public IP ───────────────
# Your server's public IP or domain name (for the frontend proxy)
SERVER_IP=your.server.public.ip
DOMAIN_NAME=   # e.g., atlasai.example.com (if you have a domain)

# ─── AI Agent Service (Optional) ────────────────
OPENAI_API_KEY=  # Only needed if using AI agents
