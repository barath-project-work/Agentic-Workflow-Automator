# =============================================================================
# AtlasAI - Environment Configuration
# =============================================================================
# ⚠️ WARNING: This file contains secrets. NEVER commit this file to version
# control. It is already in .gitignore.
#
# Copy this file to .env and fill in your real values.
# =============================================================================

# ─── PostgreSQL (Primary Database) ──────────────────────────────────────────
POSTGRES_USER=atlasai
POSTGRES_PASSWORD=devpassword
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Database Names (one per service) ────────────────────────────────────────
AUTH_DB_NAME=atlasai_auth
CRM_DB_NAME=atlasai_crm
TASKS_DB_NAME=atlasai_tasks
WORKFLOW_DB_NAME=atlasai_workflow

# ─── Redis (Cache & Sessions) ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── Kafka (Event Bus) ─────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8085

# ─── JWT (Authentication) ──────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=change-this-to-a-256-bit-secret-key-generated-by-openssl
JWT_EXPIRATION_MS=3600000

# ─── OpenAI (AI Agent Service) ──────────────────────────────────────────────
# Sign up at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-placeholder-replace-with-your-key
OPENAI_ORGANIZATION_ID=
# Model selection: gpt-4-turbo for planning, gpt-4o-mini for routine tasks
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=4096

# ─── Email Provider (Notification Service) ──────────────────────────────────
# Sign up at: https://sendgrid.com (free tier: 100 emails/day)
SENDGRID_API_KEY=SG.placeholder-replace-with-your-key
EMAIL_FROM_ADDRESS=sales@atlasai.dev

# ─── Calendar Integration (Notification Service) ────────────────────────────
# Google Calendar API or Microsoft Graph API
CALENDAR_PROVIDER=google
GOOGLE_CLIENT_ID=placeholder-client-id
GOOGLE_CLIENT_SECRET=placeholder-client-secret

# ─── Monitoring & Observability ────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
JAEGER_PORT=16686

# ─── Service Ports (Spring Boot) ────────────────────────────────────────────
AUTH_SERVICE_PORT=8081
CUSTOMER_SERVICE_PORT=8082
WORKFLOW_SERVICE_PORT=8083
TASK_SERVICE_PORT=8084
NOTIFICATION_SERVICE_PORT=8085
SEARCH_SERVICE_PORT=8086
AI_AGENT_SERVICE_PORT=8087
