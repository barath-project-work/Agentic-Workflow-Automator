# AtlasAI Frontend — Nginx Config Template
# Backend URLs are injected at container boot via docker-entrypoint.sh
# Uses envsubst variable syntax: ${VARIABLE}

server {
    listen 80;
    server_name _;

    root /usr/share/nginx/html;
    index index.html;

    # ─── Gzip compression ───────────────────────
    gzip on;
    gzip_comp_level 6;
    gzip_min_length 256;
    gzip_types
        text/plain
        text/css
        application/json
        application/javascript
        application/x-javascript
        text/xml
        application/xml
        application/xml+rss
        text/javascript
        image/svg+xml
        font/woff
        font/woff2;

    # ─── Security headers ───────────────────────
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # ─── API proxy — Auth Service ──
    location /api/auth {
        proxy_pass ${AUTH_SERVICE_URL};
        proxy_http_version 1.1;
        proxy_set_header Host ${AUTH_SERVICE_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 10s;
        proxy_send_timeout    10s;
        proxy_read_timeout    10s;
        proxy_request_buffering off;
    }

    # ─── API proxy — Customer Service ──
    location /api/customers {
        proxy_pass ${CUSTOMER_SERVICE_URL};
        proxy_http_version 1.1;
        proxy_set_header Host ${CUSTOMER_SERVICE_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 10s;
        proxy_send_timeout    10s;
        proxy_read_timeout    10s;
        proxy_request_buffering off;
    }

    # ─── API proxy — Customer Service (/api/opportunities/*) ──
    location /api/opportunities {
        proxy_pass ${CUSTOMER_SERVICE_URL};
        proxy_http_version 1.1;
        proxy_set_header Host ${CUSTOMER_SERVICE_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 10s;
        proxy_send_timeout    10s;
        proxy_read_timeout    10s;
        proxy_request_buffering off;
    }

    # ─── API proxy — Workflow Service ──
    location /api/workflows {
        proxy_pass ${WORKFLOW_SERVICE_URL};
        proxy_http_version 1.1;
        proxy_set_header Host ${WORKFLOW_SERVICE_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 10s;
        proxy_send_timeout    10s;
        proxy_read_timeout    10s;
        proxy_request_buffering off;
    }

    # ─── API proxy — Task Service ──
    location /api/tasks {
        proxy_pass ${TASK_SERVICE_URL};
        proxy_http_version 1.1;
        proxy_set_header Host ${TASK_SERVICE_HOST};
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 10s;
        proxy_send_timeout    10s;
        proxy_read_timeout    10s;
        proxy_request_buffering off;
    }

    # ─── Static assets with long cache ──────────
    location /assets/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location /founder/ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }

    # ─── SPA fallback — all other routes → index.html ───
    location / {
        try_files $uri $uri/ /index.html;
        add_header Cache-Control "no-cache, must-revalidate";
    }

    # ─── Deny access to hidden files ────────────
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # ─── Health check endpoint (returns 200) ────
    location /health {
        access_log off;
        return 200 "OK";
        add_header Content-Type text/plain;
    }
}
